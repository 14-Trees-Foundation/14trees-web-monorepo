{
  "all": true,
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.d.ts",
    "src/swagger.ts",
    "src/testServer.ts",
    "src/migrations/**",
    "src/seeders/**",
    "src/config/**",
    "test/**/*",
    "coverage/**/*",
    "dist/**/*"
  ],
  "reporter": ["text", "text-summary", "html", "lcov"],
  "report-dir": "coverage",
  "check-coverage": true,
  "lines": 1,
  "statements": 1,
  "functions": 1,
  "branches": 1,
  "skip-full": false,
  "temp-dir": ".nyc_output",
  "cache": true
}
